{
  "expo": {
    "name": "fortu-gestor",
    "slug": "project-test2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fortugestor",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.fortu.gestor"
    },
    "android": {
      "package": "com.fortu.gestor",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A1931",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Fortu Gestor usa la cámara para capturar tus documentos de identidad durante el registro.",
          "photosPermission": "Fortu Gestor accede a tus fotos para adjuntar los documentos del registro."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ddf20e41-187f-4c47-9d8e-fe26adeb7eb3"
      }
    },
    "owner": "axiasmedia"
  }
}
